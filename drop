<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>drop</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Share+Tech+Mono&display=swap');

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --bg:   #000;
    --text: #fff;
    --dim:  rgba(255,255,255,0.35);
    --lime: #c8f028;
  }

  html, body {
    width: 100%; height: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    user-select: none;
  }


  #home-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 13px 40px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    display: inline-block;
  }
  #home-btn:hover { background: #fff; color: #000; }

  #board-wrap { position: relative; }

  #board {
    display: grid;
    gap: 4px;
    padding: 4px;
    background: rgba(0,0,0,0.6);
    box-shadow: 0 0 40px rgba(0,0,0,0.8), inset 0 0 20px rgba(0,0,0,0.5);
  }

  #hud {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    justify-content: space-around;
    padding: 8px 12px 6px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.75), transparent);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: var(--dim);
    text-align: center;
    pointer-events: none;
    z-index: 5;
  }
  #hud .val {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    display: block;
  }

  .tile {
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
    background: #000;
    transition: transform 0.08s ease;
  }
  .tile:active { transform: scale(0.93); }

  .tile-inner {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transition: transform 0.35s ease;
  }
  .tile.flipped .tile-inner,
  .tile.matched .tile-inner { transform: rotateY(180deg); }

  .tile-front, .tile-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tile-front { background: #000; }

  .tile-back {
    transform: rotateY(180deg);
    background: #000;
  }

  .tile-back img {
    position: absolute;
    width: 75%; height: 75%;
    top: 12.5%; left: 12.5%;
    object-fit: contain;
    pointer-events: none;
  }

  .tile.matched .tile-back  { background: #000; }
  .tile.matched              { box-shadow: inset 0 0 0 1px var(--lime); }

  .tile.wrong .tile-back { background: #000; }
  @keyframes wrongShake {
    0%,100% { transform: translateX(0); }
    25%      { transform: translateX(-4px); }
    75%      { transform: translateX(4px); }
  }
  .tile.wrong { animation: wrongShake 0.25s ease; }

  #overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    background: #000;
    z-index: 10;
  }
  #overlay h2 {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    letter-spacing: 0.2em;
    color: var(--lime);
    text-transform: uppercase;
    text-shadow: 0 0 16px rgba(200,240,40,0.4);
  }
  #overlay h2.ready { text-shadow: none; }

  #score-row { display: flex; align-items: flex-end; gap: 20px; }
  .score-block { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .score-label { font-size: 0.58rem; letter-spacing: 0.15em; color: var(--dim); }
  .big-num { font-family: 'Orbitron', sans-serif; font-size: 2.2rem; font-weight: 900; line-height: 1; }
  #big-score { font-size: 3.5rem; }
  #big-best  { color: var(--lime); }
  .score-divider { width: 1px; height: 44px; background: rgba(255,255,255,0.15); margin-bottom: 6px; }

  #diff-toggle { display: flex; border-radius: 2px; overflow: hidden; }
  .diff-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 8px 18px;
    background: transparent;
    border: none;
    color: var(--dim);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .diff-btn.active { background: #fff; color: #000; }

  #play-btn {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 13px 40px;
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    display: inline-block;
    transition: background 0.15s, color 0.15s;
  }
  #play-btn:hover { background: #fff; color: #000; }

  @keyframes seqPulse {
    0%   { box-shadow: inset 0 0 0 2px var(--lime), 0 0 18px var(--lime); background: rgba(200,240,40,0.15); }
    100% { box-shadow: none; background: #000; }
  }
  .tile.seq-flash .tile-back { animation: seqPulse 0.28s ease forwards; }

  #countdown {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 8;
    font-family: 'Orbitron', sans-serif;
    font-size: 5rem;
    font-weight: 900;
    color: var(--lime);
    text-shadow: none;
    background: rgba(0,0,0,0.55);
    pointer-events: none;
  }
  #countdown.active { display: flex; }
  .btn-group {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 18px;
  }
  .btn-group #play-btn,
  .btn-group #home-btn {
    display: block;
    text-align: center;
    box-sizing: border-box;
  }
</style>
</head>
<body>

<div id="board-wrap">
  <div id="hud">
    <div>ROUND<br><span class="val" id="round-el">—</span></div>
    <div>SCORE<br><span class="val" id="score-el">0</span></div>
    <div>BEST<br><span class="val" id="best-el">0</span></div>
    <div>ERRORS<br><span class="val" id="errors-el">0</span></div>
  </div>
  <div id="board"></div>
  <div id="countdown"></div>
  <div id="overlay">
    <h2 class="ready" id="ov-title">Rally</h2>
    <div id="score-row" style="display:none">
      <div class="score-block">
        <span class="score-label">SCORE</span>
        <div id="big-score" class="big-num"></div>
      </div>
      <div class="score-divider"></div>
      <div class="score-block">
        <span class="score-label">BEST</span>
        <div id="big-best" class="big-num"></div>
      </div>
      <div class="score-divider"></div>
      <div class="score-block">
        <span class="score-label">ERRORS</span>
        <div id="big-errors" class="big-num"></div>
      </div>
    </div>
    <div id="diff-toggle">
      <button class="diff-btn active" id="btn-easy">SOFT</button>
      <button class="diff-btn" id="btn-hard">HARD</button>
    </div>
    <div class="btn-group"><button id="play-btn">PLAY</button><a id="home-btn" href="index.html">HOME</a></div>
  </div>
</div>

<script>
const COLS = 4, ROWS = 6, GAP = 4;

const DIFF = {
  easy: { seqLen: 3, showMs: 600, gapMs: 220, maxErrors: 5 },
  hard: { seqLen: 5, showMs: 350, gapMs: 140, maxErrors: 2 },
};

const TILE_IMAGE = 'https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/PNG_transparency_demonstration_1.png/280px-PNG_transparency_demonstration_1.png';

const $ = id => document.getElementById(id);
const boardEl   = $('board'), overlay = $('overlay'), countdownEl = $('countdown');
const ovTitle   = $('ov-title'), scoreRow = $('score-row');
const bigScore  = $('big-score'), bigBest = $('big-best'), bigErrors = $('big-errors');
const playBtn   = $('play-btn');
const roundEl   = $('round-el'), scoreEl = $('score-el');
const bestEl    = $('best-el'), errorsEl = $('errors-el');
const btnEasy   = $('btn-easy'), btnHard = $('btn-hard');

const TILE_SRC = (() => {
  const c = document.createElement('canvas');
  c.width = c.height = 64;
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#fff';
  ctx.fillRect(4,4,56,56);
  ctx.fillStyle = '#c8f028';
  ctx.fillRect(12,12,40,40);
  ctx.fillStyle = '#000';
  ctx.fillRect(20,20,24,24);
  return c.toDataURL();
})();

let difficulty = 'easy';
[btnEasy, btnHard].forEach((btn, i) => {
  const keys = ['easy','hard'];
  btn.addEventListener('click', () => {
    difficulty = keys[i];
    [btnEasy, btnHard].forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    bestEl.textContent = best[difficulty];
  });
});

let tileSize, cells = [];

function buildBoard() {
  const maxW = Math.min(window.innerWidth  - 40, 340);
  const maxH = Math.min(window.innerHeight - 80, 480);
  tileSize = Math.min(
    Math.floor((maxW - GAP * (COLS - 1) - 8) / COLS),
    Math.floor((maxH - GAP * (ROWS - 1) - 8) / ROWS)
  );
  boardEl.style.gridTemplateColumns = `repeat(${COLS}, ${tileSize}px)`;
  boardEl.style.gridTemplateRows    = `repeat(${ROWS}, ${tileSize}px)`;
  boardEl.innerHTML = '';
  cells = [];
  for (let r = 0; r < ROWS; r++) {
    cells[r] = [];
    for (let c = 0; c < COLS; c++) {
      const tile  = document.createElement('div');
      tile.className = 'tile';
      tile.dataset.row = r; tile.dataset.col = c;
      tile.dataset.idx = r * COLS + c;
      const inner = document.createElement('div');
      inner.className = 'tile-inner';
      const front = document.createElement('div');
      front.className = 'tile-front';
      const back  = document.createElement('div');
      back.className = 'tile-back';
      const img = document.createElement('img');
      img.src = TILE_SRC;
      img.alt = '';
      back.appendChild(img);
      inner.append(front, back);
      tile.appendChild(inner);
      boardEl.appendChild(tile);
      cells[r][c] = tile;
    }
  }
}

let audioCtx;
const getCtx = () => audioCtx ??= new (window.AudioContext || window.webkitAudioContext)();
function chain(ctx, ...nodes) {
  for (let i = 0; i < nodes.length - 1; i++) nodes[i].connect(nodes[i+1]);
  nodes.at(-1).connect(ctx.destination);
}

function playReveal(index) {
  const ctx = getCtx(), t = ctx.currentTime;
  const freqs = [220,261,294,330,370,415,440,494,523,587,659,698,784,880];
  const f = freqs[index % freqs.length];
  const osc  = Object.assign(ctx.createOscillator(), { type: 'sine' });
  const gain = ctx.createGain();
  osc.frequency.value = f;
  gain.gain.setValueAtTime(0.25, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
  chain(ctx, osc, gain);
  osc.start(t); osc.stop(t + 0.25);
}

function playMatch() {
  const ctx = getCtx(), t = ctx.currentTime;
  [523, 659, 784].forEach((f, i) => {
    const o = Object.assign(ctx.createOscillator(), { type: 'triangle' });
    const g = ctx.createGain();
    o.frequency.value = f;
    const st = t + i * 0.07;
    g.gain.setValueAtTime(0.2, st);
    g.gain.exponentialRampToValueAtTime(0.001, st + 0.25);
    chain(ctx, o, g);
    o.start(st); o.stop(st + 0.28);
  });
}

function playWrong() {
  const ctx = getCtx(), t = ctx.currentTime;
  const o = Object.assign(ctx.createOscillator(), { type: 'sawtooth' });
  const g = ctx.createGain();
  o.frequency.setValueAtTime(180, t);
  o.frequency.exponentialRampToValueAtTime(90, t + 0.2);
  g.gain.setValueAtTime(0.18, t);
  g.gain.exponentialRampToValueAtTime(0.001, t + 0.22);
  chain(ctx, o, g);
  o.start(t); o.stop(t + 0.25);
}

function playSeqTone(i) {
  const ctx = getCtx(), t = ctx.currentTime;
  const scale = [262,294,330,349,392,440,494,523];
  const f = scale[i % scale.length];
  const osc  = Object.assign(ctx.createOscillator(), { type: 'sine' });
  const gain = ctx.createGain();
  osc.frequency.value = f;
  gain.gain.setValueAtTime(0.18, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + 0.18);
  chain(ctx, osc, gain);
  osc.start(t); osc.stop(t + 0.2);
}

let score, best = { easy:0, hard:0 }, errors;
let round, sequence, sequenceStep;
let running, inputLocked;

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

function idxToRC(idx) { return [Math.floor(idx / COLS), idx % COLS]; }

async function showSequence() {
  inputLocked = true;
  const cfg = DIFF[difficulty];
  await delay(400);
  for (let i = 0; i < sequence.length; i++) {
    const [r, c] = idxToRC(sequence[i]);
    const tile = cells[r][c];
    playSeqTone(i, sequence.length);
    tile.classList.add('flipped');
    await delay(cfg.showMs);
    tile.classList.remove('flipped');
    await delay(cfg.gapMs);
  }
  await delay(200);
  inputLocked = false;
}

function delay(ms) { return new Promise(res => setTimeout(res, ms)); }

async function handleTap(r, c) {
  if (!running || inputLocked) return;
  const idx = r * COLS + c;
  const tile = cells[r][c];
  if (tile.classList.contains('seq-done')) return;
  const expected = sequence[sequenceStep];
  if (idx === expected) {
    inputLocked = true;
    tile.classList.add('flipped');
    playReveal(sequenceStep);
    await delay(220);
    tile.classList.remove('flipped');
    tile.classList.add('seq-done');
    inputLocked = false;
    score += 10 + round * 2;
    scoreEl.textContent = score;
    sequenceStep++;
    if (sequenceStep === sequence.length) {
      await delay(300);
      playMatch();
      await delay(500);
      round++;
      roundEl.textContent = round;
      clearSeqDone();
      sequence = buildSequence();
      sequenceStep = 0;
      await showSequence();
    }
  } else {
    inputLocked = true;
    tile.classList.add('flipped', 'wrong');
    playWrong();
    errors++;
    errorsEl.textContent = errors;
    await delay(400);
    tile.classList.remove('flipped', 'wrong');
    endGame();
  }
}

function clearSeqDone() {
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++)
      cells[r][c].classList.remove('seq-done', 'matched');
}

function buildSequence() {
  const len = DIFF[difficulty].seqLen + Math.floor((round - 1) / 2);
  const total = ROWS * COLS;
  const seq = [];
  let prev = -1;
  for (let i = 0; i < len; i++) {
    let idx;
    do { idx = Math.floor(Math.random() * total); } while (idx === prev);
    seq.push(idx);
    prev = idx;
  }
  return seq;
}

function runCountdown() {
  return new Promise(resolve => {
    let n = 3;
    countdownEl.textContent = n;
    countdownEl.classList.add('active');
    const iv = setInterval(() => {
      n--;
      if (n <= 0) { clearInterval(iv); countdownEl.classList.remove('active'); resolve(); }
      else countdownEl.textContent = n;
    }, 700);
  });
}

async function startGame() {
  score = 0; errors = 0; round = 1;
  running = true; inputLocked = true;
  sequenceStep = 0;
  scoreEl.textContent  = 0;
  errorsEl.textContent = 0;
  roundEl.textContent  = 1;
  bestEl.textContent   = best[difficulty];
  overlay.style.display = 'none';
  for (let r = 0; r < ROWS; r++)
    for (let c = 0; c < COLS; c++)
      cells[r][c].className = 'tile';
  await runCountdown();
  sequence = buildSequence();
  await showSequence();
}

function endGame() {
  running = false; inputLocked = true;
  const key = difficulty;
  if (score > best[key]) best[key] = score;
  bestEl.textContent = best[key];
  setTimeout(() => {
    overlay.style.display = 'flex';
    ovTitle.textContent   = 'GAME OVER';
    ovTitle.className     = 'ready';
    scoreRow.style.display = 'flex';
    bigScore.textContent  = score;
    bigBest.textContent   = best[difficulty];
    bigErrors.textContent = errors;
    playBtn.textContent   = 'PLAY AGAIN';
  }, 300);
}

boardEl.addEventListener('mousedown', e => {
  const tile = e.target.closest('.tile');
  if (tile) handleTap(+tile.dataset.row, +tile.dataset.col);
});

boardEl.addEventListener('touchstart', e => {
  e.preventDefault();
  const { clientX, clientY } = e.changedTouches[0];
  const el = document.elementFromPoint(clientX, clientY)?.closest('.tile');
  if (el) handleTap(+el.dataset.row, +el.dataset.col);
}, { passive: false });

playBtn.addEventListener('click', startGame);
window.addEventListener('resize', buildBoard);

buildBoard();
</script>
</body>
</html>
